DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_APPLICATION_ID

# Lavalink Node Configuration
# Replace these with your public/private Lavalink node details
LAVALINK_HOST=your-lavalink-node.com
LAVALINK_PORT=443
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=true

# MongoDB Atlas (REQUIRED — all playlist data is stored here, NOT on the server)
# Create a free cluster at: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0-inventory.rspbi.mongodb.net/discord-bot?retryWrites=true&w=majority
# Render Self-Ping (optional — paste your Render app's public URL to keep it alive on free tier)
# Example: https://your-app-name.onrender.com
RENDER_EXTERNAL_URL=

# Spotify API Credentials (REQUIRED for Spotify playlist/track import support)
# Create a free application at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

